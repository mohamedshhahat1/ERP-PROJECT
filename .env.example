# ============================================
# ERP Project Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit the .env file to source control!
# ============================================

# --- Database ---
POSTGRES_DB=ceramic_erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=   # REQUIRED: Set a strong password (e.g., openssl rand -base64 32)
DB_PORT=5432

# --- Redis ---
REDIS_PASSWORD=      # REQUIRED: Set a strong password

# --- Security ---
SECRET_KEY=          # REQUIRED: Min 32 chars (e.g., python -c "import secrets; print(secrets.token_urlsafe(64))")

# --- API Keys ---
ANTHROPIC_API_KEY=   # Required for AI features
DEEPGRAM_API_KEY=    # Required for voice features
ELEVENLABS_API_KEY=  # Optional: for TTS

# --- Application ---
ACCESS_TOKEN_EXPIRE_MINUTES=480
AI_MODEL=claude-sonnet-4-20250514
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# --- WhatsApp (Optional) ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OWNER_PHONE=

# --- Azure Speech (Optional) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
