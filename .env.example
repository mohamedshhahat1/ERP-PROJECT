# ============================================
# ERP Project Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit the .env file to source control!
# ============================================

# --- Database ---
POSTGRES_DB=ceramic_erp
POSTGRES_USER=postgres
# REQUIRED: Set a strong password (e.g., openssl rand -base64 32)
POSTGRES_PASSWORD=changeme_strong_password_here
DB_PORT=5432

# --- Redis ---
# REQUIRED: Set a strong password
REDIS_PASSWORD=changeme_redis_password_here

# --- Security ---
# REQUIRED: Min 32 chars (e.g., python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=changeme_generate_a_64_char_random_string_here_for_jwt_signing

# --- API Keys ---
# Required for AI features
ANTHROPIC_API_KEY=
# Required for voice features
DEEPGRAM_API_KEY=
# Optional: for TTS
ELEVENLABS_API_KEY=

# --- Application ---
ACCESS_TOKEN_EXPIRE_MINUTES=480
AI_MODEL=claude-sonnet-4-20250514
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# --- WhatsApp (Optional) ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OWNER_PHONE=

# --- Azure Speech (Optional) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
